# Copiá este archivo a .env y completá tu API key de Gemini
# (se obtiene gratis en https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Modelos de Gemini a usar (podés cambiarlos sin tocar el código)
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Rutas a los documentos fuente
CSV_PATH=data/sales.csv
PDF_PATH=data/policies.pdf

# Parámetros de fragmentación para el RAG sobre el PDF
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4

# Carpeta donde se guarda el índice vectorial del PDF (se genera solo, no editar a mano)
VECTORSTORE_DIR=data/faiss_index
